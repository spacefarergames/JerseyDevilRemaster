void HUDRenderer::DrawScore( int screenWidth, int screenHeight, int score )
{
	glColor3f( 1.0f, 1.0f, 0.0f );
	glBegin( GL_LINE_LOOP );
	glVertex2i( 10, 10 );
	glVertex2i( 110, 10 );
	glVertex2i( 110, 40 );
	glVertex2i( 10, 40 );
	glEnd();

	glColor3f( 0.5f, 0.5f, 0.0f );
	glBegin( GL_QUADS );
	glVertex2i( 11, 11 );
	glVertex2i( 109, 11 );
	glVertex2i( 109, 39 );
	glVertex2i( 11, 39 );
	glEnd();

	// Draw score as text (simplified - just drawing the border for now)
	char scoreStr[32];
	std::snprintf( scoreStr, sizeof( scoreStr ), "Score: %d", score );
	// In a real implementation, this would render the text
}

void HUDRenderer::DrawHealth( int screenWidth, int screenHeight, int health )
{
	glColor3f( 1.0f, 0.0f, 0.0f );
	glBegin( GL_LINE_LOOP );
	glVertex2i( screenWidth - 110, 10 );
	glVertex2i( screenWidth - 10, 10 );
	glVertex2i( screenWidth - 10, 40 );
	glVertex2i( screenWidth - 110, 40 );
	glEnd();

	glColor3f( 0.5f, 0.0f, 0.0f );
	glBegin( GL_QUADS );
	glVertex2i( screenWidth - 109, 11 );
	glVertex2i( screenWidth - 11, 11 );
	glVertex2i( screenWidth - 11, 39 );
	glVertex2i( screenWidth - 109, 39 );
	glEnd();

	// Draw health indicators (small rectangles)
	for ( int i = 0; i < health; ++i ) {
		glColor3f( 1.0f, 0.0f, 0.0f );
		const int hx = screenWidth - 90 + i * 25;
		glBegin( GL_QUADS );
		glVertex2i( hx, 15 );
		glVertex2i( hx + 20, 15 );
		glVertex2i( hx + 20, 35 );
		glVertex2i( hx, 35 );
		glEnd();
	}
}

void HUDRenderer::DrawLevelInfo( int screenWidth, int screenHeight, int levelIndex, int levelCount, const char* levelName )
{
	glColor3f( 0.0f, 1.0f, 1.0f );
	glBegin( GL_LINE_LOOP );
	glVertex2i( screenWidth / 2 - 100, 10 );
	glVertex2i( screenWidth / 2 + 100, 10 );
	glVertex2i( screenWidth / 2 + 100, 40 );
	glVertex2i( screenWidth / 2 - 100, 40 );
	glEnd();

	glColor3f( 0.0f, 0.5f, 0.5f );
	glBegin( GL_QUADS );
	glVertex2i( screenWidth / 2 - 99, 11 );
	glVertex2i( screenWidth / 2 + 99, 11 );
	glVertex2i( screenWidth / 2 + 99, 39 );
	glVertex2i( screenWidth / 2 - 99, 39 );
	glEnd();
}

void HUDRenderer::DrawCollectibles( int screenWidth, int screenHeight, int remaining, int total )
{
	glColor3f( 0.0f, 1.0f, 0.0f );
	glBegin( GL_LINE_LOOP );
	glVertex2i( 10, screenHeight - 40 );
	glVertex2i( 110, screenHeight - 40 );
	glVertex2i( 110, screenHeight - 10 );
	glVertex2i( 10, screenHeight - 10 );
	glEnd();

	glColor3f( 0.0f, 0.5f, 0.0f );
	glBegin( GL_QUADS );
	glVertex2i( 11, screenHeight - 39 );
	glVertex2i( 109, screenHeight - 39 );
	glVertex2i( 109, screenHeight - 11 );
	glVertex2i( 11, screenHeight - 11 );
	glEnd();

	// Draw progress bar for collectibles
	if ( total > 0 ) {
		const float progress = static_cast<float>( total - remaining ) / static_cast<float>( total );
		glColor3f( 0.0f, 1.0f, 0.0f );
		glBegin( GL_QUADS );
		glVertex2i( 15, screenHeight - 35 );
		glVertex2i( 15 + static_cast<int>( 90.0f * progress ), screenHeight - 35 );
		glVertex2i( 15 + static_cast<int>( 90.0f * progress ), screenHeight - 15 );
		glVertex2i( 15, screenHeight - 15 );
		glEnd();
	}
}

} // namespace jdpc
